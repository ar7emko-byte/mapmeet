# Supabase — get these from your project dashboard (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Optional — used by the Android native Google Maps SDK. Also mirror this into
# app.json → expo.android.config.googleMaps.apiKey when you build for Android.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

# Optional — used by the MapLibre web renderer for vector tiles. If left blank
# the web map falls back to the OpenStreetMap raster preset.
EXPO_PUBLIC_MAPLIBRE_STYLE_URL=
